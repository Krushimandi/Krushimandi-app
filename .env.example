# Example environment file
# Copy to .env and fill in secrets for local/dev; use CI secrets for production builds

# Firebase (if used in JS layer)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
