FIREBASE_MEASUREMENT_ID=

# App
APP_ENV=production
API_BASE_URL=
SENTRY_DSN=

# Android signing (CI-only; prefer CI variables)
ANDROID_KEYSTORE_PATH=app/my-release-key.keystore
ANDROID_KEYSTORE_PASSWORD=kz9enabg7x
ANDROID_KEY_ALIAS=my-key-alias
