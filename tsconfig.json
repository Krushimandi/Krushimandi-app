{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "typeRoots": ["./types", "./node_modules/@types"],
    "baseUrl": "src",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@ui/*": ["ui/*"],
      "@component/*": ["component/*"]
    }

  }
}